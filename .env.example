# Variables de entorno para Docker Compose - Producción
# Copiar este archivo como .env y completar con los valores reales

# Perfil de Spring
SPRING_PROFILE=prod

# Configuración de Base de Datos PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=scheduleDB
DB_USERNAME=tu_usuario_db
DB_PASSWORD=tu_password_db

# Configuración de Seguridad - Usuario básico
SECURITY_USER_NAME=tu_usuario_admin
SECURITY_USER_PASSWORD=tu_password_admin

# JWT Configuration
JWT_PRIVATE_KEY=tu_clave_privada_jwt_aqui
JWT_USER_GENERATOR=AUTH0JWT-BACKEND

# Backend
BACKEND_PORT=8080

# Frontend
FRONTEND_PORT=80

# SonarQube Database
SONAR_JDBC_URL=jdbc:postgresql://192.168.0.100:5433/sonar
SONAR_JDBC_USERNAME=sonar
SONAR_JDBC_PASSWORD=sonar
SONAR_DB_PORT=5433

# SonarQube Tokens
SONAR_HOST_URL=http://100.108.184.57:9000
SONAR_BACKEND_TOKEN=tu_token_sonar_backend
SONAR_FRONTEND_TOKEN=tu_token_sonar_frontend
